# ===== Lark 应用凭证（必填）=====
# 在 Lark 开放平台 open.larksuite.com → 你的应用 → 凭证与基础信息 里复制
LARK_APP_ID=cli_xxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 飞书国内版（open.feishu.cn）填 feishu；Lark 国际版留空或填 lark
LARK_DOMAIN=lark

# ===== OnlyRouter（机器人用它来生成回答，必填）=====
# 去 onlyrouter.ai 控制台 → 密钥管理 创建一个 sk- 开头的 Key
ONLYROUTER_API_KEY=sk-xxxxxxxxxxxxxxxx
# 回答用的模型，默认 gpt-5.5-ab（便宜，输入 $0.5/M、输出 $4/M）
# 协议自动适配：-ab 结尾走 Anthropic 协议，其余(gpt-5.5/deepseek-v4-pro 等)走 OpenAI 协议，填啥都不会报协议错
ONLYROUTER_MODEL=gpt-5.5-ab
# 根地址，一般不用改（带不带 /v1 都行，代码会自动处理）
ONLYROUTER_BASE_URL=https://api.onlyrouter.ai

# ===== Bug 上报（可选）=====
# 机器人判定用户遇到的是 OnlyRouter 平台真 bug（而非配置/用法问题）时，
# 自动把问题转发到这个 Lark 群。留空则不上报。
# 获取方式：目标群 → 群设置 → 群机器人 → 添加机器人 → 自定义机器人 → 复制 Webhook 地址
LARK_BUG_WEBHOOK_URL=
